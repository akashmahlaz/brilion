# ==========================================
# Brilion — Required Environment Variables
# ==========================================

# --- Database ---
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/brilion
DB_NAME=brilion

# --- Auth.js ---
AUTH_SECRET=          # Generate with: openssl rand -base64 32
AUTH_URL=https://yourdomain.com/api/auth
FRONTEND_URL=https://yourdomain.com

# --- OAuth Providers ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
MICROSOFT_ENTRA_ID_CLIENT_ID=
MICROSOFT_ENTRA_ID_CLIENT_SECRET=
MICROSOFT_ENTRA_ID_TENANT_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- AI / LLM API Keys ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# --- Messaging ---
TELEGRAM_BOT_TOKEN=

# --- Payments ---
STRIPE_SECRET_KEY=
STRIPE_ACCOUNT_ID=

# --- Email ---
RESEND_API_KEY=
FROM_EMAIL=

# --- SMS ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Image Hosting ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Analytics (Client-side) ---
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=

# --- App ---
VITE_APP_TITLE=Brilion
VITE_GOOGLE_CLIENT_ID=
SERVER_URL=https://yourdomain.com
